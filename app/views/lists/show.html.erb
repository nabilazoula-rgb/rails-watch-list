<div class="banner" style="background-image: url('<%= image_path("cinema.jpg") %>');">
  <div class="banner-content">
    <h1><%= @list.name %></h1>
  </div>
</div>

<div class="container my-4">

  <p>ID: <%= @list.id %></p>

  <%= link_to "Back to all lists", lists_path, class: "btn btn-secondary mb-3" %>

  <h2>Movies in this list</h2>

  <ul>
    <% @list.bookmarks.each do |bookmark| %>
      <li>
        <strong><%= bookmark.movie.title %></strong> — <%= bookmark.comment %>

        <%= link_to "Delete",
                    bookmark_path(bookmark),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </li>
    <% end %>
  </ul>

  <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-primary mt-3" %>

</div>
